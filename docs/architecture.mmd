graph TB
    subgraph Users
        User([User])
    end

    subgraph AWS Cloud
        Cognito[Cognito<br/>User Pool]

        subgraph CloudFront
            CF[CloudFront<br/>Distribution]
        end

        S3Front[S3<br/>SvelteKit Static]
        S3Upload[S3<br/>File Uploads]
        ECR[ECR<br/>Docker Image]
        SQS[SQS<br/>Message Queue]
        SES[SES<br/>Email]
        Lambda[Lambda<br/>Thumbnail]
        R53[Route 53]

        subgraph VPC
            subgraph Public Subnet
                subgraph K3s on EC2
                    Traefik[Traefik<br/>Ingress]
                    API[Spring Boot<br/>chat-api Pod]
                    ES[Elasticsearch<br/>Pod]
                    ArgoCD[ArgoCD]
                    CertManager[cert-manager<br/>Let's Encrypt]
                end
            end

            subgraph Private Subnets
                RDS[(RDS<br/>PostgreSQL)]
                Redis[(ElastiCache<br/>Redis)]
            end
        end
    end

    User -->|HTTPS| CF
    User -->|HTTPS| R53
    User -->|JWT Auth| Cognito
    R53 -->|chat.tommykeyapp.com| CF
    R53 -->|argocd.tommykeyapp.com| Traefik
    CF -->|Default /| S3Front
    CF -->|/api/* /ws| Traefik
    Traefik --> API
    API --> RDS
    API --> Redis
    API --> SQS
    API -->|Presigned URL| S3Upload
    API --> ES
    SQS --> API
    API --> SES
    S3Upload -->|Event| Lambda
    ECR -.->|Image Pull| API
    ArgoCD -->|GitOps Sync| API
    CertManager -->|TLS| Traefik

    classDef compute fill:#FF9900,stroke:#232F3E,color:#232F3E
    classDef storage fill:#3F8624,stroke:#232F3E,color:white
    classDef database fill:#3B48CC,stroke:#232F3E,color:white
    classDef security fill:#DD344C,stroke:#232F3E,color:white
    classDef network fill:#8C4FFF,stroke:#232F3E,color:white

    class CF,Traefik,SQS,Lambda,SES compute
    class S3Front,S3Upload,ECR storage
    class RDS,Redis,ES database
    class Cognito,CertManager security
    class API,ArgoCD,R53 network
