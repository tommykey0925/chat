graph TB
    subgraph Users
        User([User])
    end

    subgraph AWS Cloud
        Cognito[Cognito<br/>User Pool]

        subgraph CloudFront
            CF[CloudFront<br/>Distribution]
        end

        S3Front[S3<br/>SvelteKit Static]
        S3Upload[S3<br/>File Uploads]
        ECR[ECR<br/>Docker Image]
        SQS[SQS<br/>Message Queue]

        subgraph VPC
            subgraph Public Subnets
                ALB[ALB<br/>Load Balancer]
                NAT[NAT Gateway]
            end

            subgraph Private Subnets
                subgraph EKS Cluster
                    API[Spring Boot<br/>chat-api Pod]
                    ES[Elasticsearch<br/>Pod]
                    ImageUpdater[ArgoCD<br/>Image Updater]
                end
                RDS[(RDS<br/>PostgreSQL)]
                Redis[(ElastiCache<br/>Redis)]
            end
        end
    end

    User -->|HTTPS| CF
    User -->|JWT Auth| Cognito
    CF -->|Default /| S3Front
    CF -->|/api/*| ALB
    CF -->|/ws| ALB
    ALB --> API
    API --> RDS
    API --> Redis
    API --> SQS
    API -->|Presigned URL| S3Upload
    API --> ES
    ECR -.->|Image Pull| API
    ImageUpdater -->|Digest監視| ECR
    ImageUpdater -->|Sync| API
    API -.->|IRSA| SQS
    API -.->|IRSA| S3Upload

    classDef aws fill:#FF9900,stroke:#232F3E,color:#232F3E
    classDef compute fill:#ED7100,stroke:#232F3E,color:white
    classDef storage fill:#3F8624,stroke:#232F3E,color:white
    classDef database fill:#3B48CC,stroke:#232F3E,color:white
    classDef security fill:#DD344C,stroke:#232F3E,color:white
    classDef network fill:#8C4FFF,stroke:#232F3E,color:white

    class CF,ALB,NAT,SQS compute
    class S3Front,S3Upload,ECR storage
    class RDS,Redis,ES database
    class Cognito security
    class API,ImageUpdater network
